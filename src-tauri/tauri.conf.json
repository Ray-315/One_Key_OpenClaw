{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "one_key_openclaw",
  "version": "0.1.0",
  "identifier": "com.openclaw.onekey",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "one_key_openclaw",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Ray-315/One_Key_OpenClaw/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  }
}
